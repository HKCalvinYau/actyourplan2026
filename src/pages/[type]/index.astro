---
import Layout from '../../layouts/Layout.astro';
import ArticleCard from '../../components/ArticleCard';
import { getPosts } from '../../lib/d1';
import { getTranslations, getLocalePath, defaultLocale } from '../../lib/i18n';

const { type } = Astro.params;

// 驗證 type 是否有效
const validTypes = ['blueprints', 'armory', 'signals', 'experiments'];
if (!type || !validTypes.includes(type)) {
  return Astro.redirect('/404');
}

// 確保 locale 為字串，避免 [object Object]
const localeRaw = Astro.locals?.locale;
const currentLocale = typeof localeRaw === 'string' ? localeRaw : defaultLocale;
const t = getTranslations(currentLocale);
const sectionInfoRaw = t.sections?.[type as keyof typeof t.sections];
const sectionInfo = sectionInfoRaw && typeof sectionInfoRaw === 'object' && 'title' in sectionInfoRaw
  ? { title: String(sectionInfoRaw.title ?? type), subtitle: String(sectionInfoRaw.subtitle ?? ''), description: String(sectionInfoRaw.description ?? '') }
  : { title: type.toUpperCase(), subtitle: '', description: '' };

// 1. 獲取資料
let posts: any[] = [];
try {
  const dbPosts = await getPosts(Astro.locals?.runtime?.env?.DB ?? null, type);
  const parseMeta = (post: { metadata?: string; created_at: number; type: string }) => {
    try { return JSON.parse(post.metadata || '{}'); } catch { return {}; }
  };
  posts = dbPosts.map(post => ({
    ...post,
    ...parseMeta(post),
    date: new Date(post.created_at).toISOString(),
    contentType: post.type
  }));
} catch (e) {
  console.error(`Error fetching ${type}:`, e);
}

const noDataText = typeof t?.common?.noData === 'string' ? t.common.noData : '沒有資料';
---

<Layout title={`${sectionInfo.title} | THE BASE`}>
  <div class="min-h-screen bg-background">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <!-- Page Header -->
      <div class="mb-12">
        <h1 class="text-4xl md:text-5xl font-heading font-bold uppercase mb-4 text-primary">
          {sectionInfo.title}
        </h1>
        <p class="text-text-muted font-mono text-lg">
          {sectionInfo.subtitle}
        </p>
      </div>

      <!-- Header Text / Description -->
      <div class="mb-12 bg-surface border-2 border-border p-8">
        <div class="font-mono text-text-main text-sm md:text-base leading-relaxed">
          <p>
            {sectionInfo.description}
          </p>
        </div>
      </div>

      <!-- List View -->
      {posts.length === 0 ? (
        <div class="bg-surface border-2 border-border p-8 text-center">
          <p class="text-text-muted font-mono">
            {noDataText}
          </p>
        </div>
      ) : (
        <div class="bg-surface border-2 border-border">
          <div class="divide-y divide-border">
            {posts.map((post) => (
              <div class="p-6">
                <ArticleCard
                  slug={String(post.slug ?? '')}
                  title={String(post.title ?? '')}
                  date={String(post.date ?? '')}
                  type={String(post.type ?? type).toUpperCase()}
                  rank={typeof post.rank === 'string' ? post.rank : 'PVT'}
                  href={getLocalePath(currentLocale, `/${post.type}/${post.slug}`)}
                />
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
  </div>
</Layout>
